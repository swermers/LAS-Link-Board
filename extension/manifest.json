{
  "manifest_version": 3,
  "name": "LAS LinkBoard Tracker",
  "version": "1.1",
  "description": "Track email opens from Gmail newsletters. Adds a tracking toggle next to Send in Gmail — on by default, one-click to disable per email.",
  "permissions": ["activeTab", "storage", "identity"],
  "icons": {
    "16": "icon48.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon48.png",
      "48": "icon48.png"
    }
  }
}
