{
  "manifest_version": 3,
  "name": "LAS LinkBoard Tracker",
  "version": "1.5",
  "description": "Track email opens from Gmail newsletters with a simple toggle next to Send.",
  "permissions": ["activeTab", "storage", "identity"],
  "host_permissions": ["https://*.supabase.co/*"],
  "icons": {
    "16": "icon48.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon48.png",
      "48": "icon48.png"
    }
  }
}
